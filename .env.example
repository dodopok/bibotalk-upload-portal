# ── Sessão (obrigatório em produção: string aleatória com 32+ caracteres) ──
NUXT_SESSION_PASSWORD=troque-por-uma-string-aleatoria-de-32-chars

# ── Login Google (Google Cloud Console → APIs & Services → Credentials) ──
# Redirect URI autorizada: https://SEU-DOMINIO/auth/google (e http://localhost:3000/auth/google em dev)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
# E-mails autorizados a entrar, separados por vírgula
NUXT_AUTHORIZED_EMAILS=dodopokcamilo@gmail.com

# ── WordPress ──
# URL do site (sem barra no final)
NUXT_WP_URL=https://bibotalk.com
# Usuário do WP e Application Password (Usuários → Perfil → Application Passwords)
NUXT_WP_USER=
NUXT_WP_APP_PASSWORD=

# ── FTP (mesmo servidor onde os mp3 ficam hoje) ──
NUXT_FTP_HOST=
NUXT_FTP_PORT=21
NUXT_FTP_USER=
NUXT_FTP_PASSWORD=
# true para FTPS (FTP sobre TLS explícito)
NUXT_FTP_SECURE=false
# Pasta remota onde os mp3 são gravados
NUXT_FTP_REMOTE_DIR=/public_html/podcast
# URL pública que corresponde à pasta acima (vira o link do enclosure)
NUXT_MP3_PUBLIC_BASE_URL=https://bibotalk.com/podcast

# ── Spotify ──
# Link do painel do programa no Spotify for Creators (botão "Subir vídeo")
NUXT_PUBLIC_SPOTIFY_CREATORS_URL=https://creators.spotify.com
